# LOGESCO v2 - Configuration Déploiement Local
NODE_ENV=local
PORT=8080

# Base de données SQLite locale
DATABASE_URL=file:../database/logesco.db

# Sécurité JWT
JWT_SECRET=logesco_local_secret_key_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Configuration CORS pour application locale
CORS_ORIGIN=http://localhost:*,file://*

# Logging
LOG_LEVEL=info
LOG_FILE=../logs/logesco-api.log

# Uploads
UPLOAD_DIR=../uploads
MAX_FILE_SIZE=10485760

# Rate limiting (plus permissif en local)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Configuration spécifique au déploiement local
LOCAL_DEPLOYMENT=true
AUTO_MIGRATE=true
CREATE_DEFAULT_ADMIN=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123