# LOGESCO v2 - Configuration Environnement Cloud

# Base de données PostgreSQL
POSTGRES_DB=logesco
POSTGRES_USER=logesco_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# API Configuration
API_PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Web Configuration
WEB_PORT=80

# Redis Configuration
REDIS_PORT=6379

# Monitoring et Logging
LOG_LEVEL=info
ENABLE_MONITORING=true

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=logesco-backups

# SSL/TLS Configuration
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/logesco.crt
SSL_KEY_PATH=/etc/ssl/private/logesco.key

# Performance
MAX_CONNECTIONS=100
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100